rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Bookings ─────────────────────────────────────────────────────────────
    // Anyone can create a booking (no login required for customers)
    // Only the booking owner or admin can read their own booking
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isAdmin());
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Users can read/write only their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    // Anyone can read approved reviews; logged-in users can create
    match /reviews/{reviewId} {
      allow read: if resource.data.approved == true;
      allow create: if request.auth != null;
    }

    // ── Coupons ───────────────────────────────────────────────────────────────
    // Anyone can read active coupons (needed for validation at checkout)
    // Only admin can write
    match /coupons/{couponId} {
      allow read: if resource.data.active == true;
      allow write: if request.auth != null && isAdmin();
    }

    // ── Chat History ──────────────────────────────────────────────────────────
    // Anyone can write chat messages; only admin can read
    match /chatHistory/{docId} {
      allow create: if true;
      allow read: if request.auth != null && isAdmin();
    }

    // ── Admin helper ──────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
  }
}
